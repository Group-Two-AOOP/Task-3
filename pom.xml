pipeline {
    agent any

    tools {
        maven 'Maven' // Make sure this matches the Maven name in Global Tool Config
    }

    environment {
        SONARQUBE = 'SonarQube' // Make sure this matches your SonarQube server in Jenkins
    }

    stages {

        stage('Checkout SCM') {
            steps {
                // Checkout only once, avoids double git fetch
                git(
                    url: 'https://github.com/Group-Two-AOOP/TaskTwo.git',
                    branch: 'main',
                    credentialsId: 'mee'
                )
            }
        }

        stage('Build') {
            steps {
                // Skip tests and ensure Maven uses Jenkins configured tool
                bat 'mvn clean install -Dmaven.test.skip=true'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv("${SONARQUBE}") {
                    bat 'mvn sonar:sonar -Dmaven.test.skip=true'
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    // Wait for SonarQube Quality Gate with timeout
                    timeout(time: 30, unit: 'MINUTES') { // increased timeout
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline aborted: Quality Gate status = ${qg.status}"
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline completed successfully!"
        }
        failure {
            echo "Pipeline failed. Check logs and SonarQube report."
        }
        aborted {
            echo "Pipeline was aborted due to timeout or manual stop."
        }
    }
}
