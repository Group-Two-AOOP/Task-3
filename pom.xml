pipeline {
    agent any

    environment {
        SONAR = "SonarQube" // your SonarQube server name
    }

    stages {
        stage('Checkout SCM') {
            steps {
                git(
                    url: 'https://github.com/Group-Two-AOOP/TaskTwo.git',
                    credentialsId: 'mee',
                    branch: 'main'
                )
            }
        }

        stage('Build') {
            steps {
                // Use the Maven installation configured in Jenkins
                withMaven(maven: 'Maven3') { // Replace 'Maven3' with the exact name in Jenkins Global Tool
                    bat 'mvn clean install -Dmaven.test.skip=true'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv("${SONAR}") {
                    withMaven(Maven: 'Maven3') {
                        bat 'mvn sonar:sonar -Dmaven.test.skip=true'
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    timeout(time: 10, unit: 'MINUTES') {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Pipeline aborted due to Quality Gate failure: ${qg.status}"
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline completed successfully!"
        }
        failure {
            echo "Pipeline failed. Check logs and SonarQube report."
        }
        aborted {
            echo "Pipeline was aborted due to timeout or manual stop."
        }
    }
}
